# Server
PORT=3000
NODE_ENV=development

# SendPromotion outbound subscription target
SENDPROMOTION_WEBHOOK_URL=https://www.sendpromotion.email/api/v1/api/webhooks/sendpromotion

# SendPromotion outbound API authentication
# Put your real EDM API key here
SENDPROMOTION_API_KEY=your_sendpromotion_api_key
# Common values: Authorization, X-API-Key
SENDPROMOTION_API_KEY_HEADER=Authorization
# Common values: Bearer, Token, or empty (no prefix)
SENDPROMOTION_API_KEY_PREFIX=Bearer

# SendPromotion inbound webhook verification
# Used to validate X-SendPromotion-Signature (HMAC-SHA256)
SENDPROMOTION_SIGNING_SECRET=your_webhook_signing_secret
