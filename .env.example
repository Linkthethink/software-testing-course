# Server
PORT=3000
NODE_ENV=development

# SendPromotion outbound subscription API target (for POST /api/subscribe)
# IMPORTANT: this must be a SendPromotion API endpoint for creating/subscribing contacts.
# Do NOT set this to your own app webhook receiver URL.
# Example only - replace with the exact endpoint from SendPromotion docs.
SENDPROMOTION_WEBHOOK_URL=https://www.sendpromotion.email/api/v1/<contacts-or-subscribe-endpoint>

# Your app inbound webhook URL (for SendPromotion -> your app event delivery)
# This value is for reference/documentation and is not used by server.js directly.
SENDPROMOTION_INBOUND_WEBHOOK_URL=https://ecom.autorocks.tech/api/webhooks/sendpromotion

# SendPromotion outbound API authentication
# Put your real EDM API key here
SENDPROMOTION_API_KEY=your_sendpromotion_api_key
# Common values: Authorization, X-API-Key
SENDPROMOTION_API_KEY_HEADER=Authorization
# Common values: Bearer, Token, or empty (no prefix)
SENDPROMOTION_API_KEY_PREFIX=Bearer

# SendPromotion inbound webhook verification
# Used to validate X-SendPromotion-Signature (HMAC-SHA256)
SENDPROMOTION_SIGNING_SECRET=your_webhook_signing_secret
